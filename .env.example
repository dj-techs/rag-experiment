# Copy to .env and fill in. .env is gitignored.

# Required: primary LLM provider
ANTHROPIC_API_KEY=

# Optional: fallback LLM provider used by src/llm.py when Anthropic fails
OPENAI_API_KEY=

# Required by SEC EDGAR for the ingestion pipeline.
# Format: "Name email@example.com" — SEC uses this to contact you on abuse.
USER_AGENT=DJames alamointelligence@gmail.com
